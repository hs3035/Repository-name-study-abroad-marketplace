# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL of the deployed app (no trailing slash)
# Used for Stripe redirect URLs and email links
NEXT_PUBLIC_URL=https://your-domain.com

# Public support email shown on /contact
SUPPORT_EMAIL=support@your-domain.com

# Optional persistent storage roots. Defaults work when a production volume is
# mounted at /app/.data on Railway/Render/Fly.
DATA_DIR=.data
UPLOAD_DIR=.data/uploads

# ─── Session / Auth ───────────────────────────────────────────────────────────
# 256-character random hex string used to sign JWT session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(128).toString('hex'))"
SESSION_SECRET=replace_with_256_char_hex_string

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Payment mode:
#   stripe = automated Stripe Checkout
#   manual = students submit bookings, then admin confirms WeChat/Alipay/bank transfer payment
PAYMENT_MODE=manual

# Manual payment mode settings. These are shown to students after they submit
# a booking. ADMIN_EMAILS can confirm payments at /admin.
ADMIN_EMAILS=owner@example.com
MANUAL_PAYMENT_CONTACT=微信/支付宝收款账号：gomentorgo
MANUAL_PAYMENT_NOTE=付款后请备注订单号，平台会人工确认。
MANUAL_WECHAT_QR_URL=/payment/wechat-pay.jpg
MANUAL_ALIPAY_QR_URL=/payment/alipay-pay.jpg
MANUAL_BANK_TRANSFER_ENABLED=false
MANUAL_BANK_NAME=
MANUAL_BANK_ACCOUNT_NAME=
MANUAL_BANK_ACCOUNT_NUMBER=
MANUAL_BANK_ROUTING_NUMBER=
MANUAL_BANK_SWIFT_CODE=
MANUAL_BANK_NOTE=银行转账后请备注订单号，平台会人工确认。

# Test keys:  sk_test_...  /  pk_test_...
# Live keys:  sk_live_...  /  pk_live_...
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret from Stripe Dashboard → Webhooks → your endpoint
# Looks like: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Comma-separated Stripe Checkout payment methods.
# Keep "card" enabled. After Stripe Dashboard enables Alipay and WeChat Pay,
# use: card,alipay,wechat_pay
STRIPE_PAYMENT_METHODS=card

# ─── Email ────────────────────────────────────────────────────────────────────
# Recommended for production OTP emails: Resend (HTTP API, more reliable than
# Gmail SMTP on cloud hosts). Verify your domain in Resend before using a
# gomentorgo.com sender address.
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@your-domain.com

# Optional SMTP fallback for sending OTP verification emails.
# Gmail: use an App Password (not your real password).
#   Settings → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=you@gmail.com

# Optional: SMS provider credentials. Phone registration is disabled in
# production until app/lib/email.ts is wired to a real SMS provider.
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE=

# ─── Deployment notes ─────────────────────────────────────────────────────────
# This app stores data in .data/*.json files and uploads in .data/uploads on
# the server filesystem.
# Vercel serverless functions have a read-only filesystem — data will NOT
# persist between requests on Vercel.
#
# Recommended hosts with persistent filesystems:
#   • Railway  (railway.app)  — add a volume mount at /app/.data
#   • Render   (render.com)   — add a persistent disk at /app/.data
#   • Fly.io   (fly.io)       — add a Fly volume at /app/.data
#   • Any VPS  (run: npm start)
